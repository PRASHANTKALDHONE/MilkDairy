<?xml version="1.0" encoding="utf-8"?>
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="#22000000">

    <item>
        <selector>

            <!-- SELECTED STATE -->
            <item android:state_selected="true">
                <shape>
                    <solid android:color="#2F8F83"/>
                    <corners android:radius="12dp"/>
                </shape>
            </item>

            <!-- DEFAULT STATE -->
            <item>
                <shape>
                    <solid android:color="#F3F6F6"/>
                    <stroke android:width="1dp" android:color="#D0D7D7"/>
                    <corners android:radius="12dp"/>
                </shape>
            </item>

        </selector>
    </item>

</ripple>