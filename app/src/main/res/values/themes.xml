<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Main light theme.
         NoActionBar is required because MainActivity uses setSupportActionBar(toolbar). -->
    <style name="Theme.MilkDairy" parent="Theme.MaterialComponents.DayNight.NoActionBar">

        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/white</item>

        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>

        <item name="colorSurface">#F6F3EA</item>
        <item name="colorOnSurface">#2E2A25</item>

        <item name="android:windowBackground">#D3D1C9</item>
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
        <item name="android:navigationBarColor">#D3D1C9</item>

        <item name="materialButtonStyle">@style/Widget.MilkDairy.Button</item>


    </style>

    <!-- Alias for screens that already use Theme.MilkDairy.NoActionBar -->
    <style name="Theme.MilkDairy.NoActionBar" parent="Theme.MilkDairy" />

    <style name="Widget.MilkDairy.Button" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">#3296A2</item>
        <item name="android:textColor">@android:color/white</item>
    </style>

    <style name="Theme.MilkDairy.AppBarOverlay" parent="ThemeOverlay.AppCompat.Dark.ActionBar" />

    <style name="CircleImageStyle">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <style name="PremiumInput" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">

        <item name="boxCornerRadiusTopStart">14dp</item>
        <item name="boxCornerRadiusTopEnd">14dp</item>
        <item name="boxCornerRadiusBottomStart">14dp</item>
        <item name="boxCornerRadiusBottomEnd">14dp</item>

        <item name="boxStrokeColor">?attr/colorPrimary</item>
        <item name="boxBackgroundColor">?attr/colorSurface</item>

        <item name="hintTextColor">?attr/colorOnSurface</item>

    </style>


</resources>
