<?xml version="1.0" encoding="utf-8"?>

<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="10dp"
    android:layout_marginTop="8dp"
    android:layout_marginBottom="4dp"
    app:cardCornerRadius="22dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="?attr/colorSurface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Top Strip -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#10B26C"/>

        <!-- Main -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="14dp">

            <!-- TOP SECTION -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <!-- AVATAR -->

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    app:cardBackgroundColor="?attr/colorSurface"
                    app:cardCornerRadius="25dp"
                    app:cardElevation="1dp">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <TextView
                            android:id="@+id/tvAvatar"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:text="RS"
                            android:textColor="#10B26C"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <!-- ONLINE DOT -->
                        <View
                            android:id="@+id/viewStatusDot"
                            android:layout_width="7dp"
                            android:layout_height="7dp"
                            android:layout_gravity="right"
                            android:layout_margin="6dp"
                            android:background="@drawable/bg_online_dot" />

                    </FrameLayout>

                </com.google.android.material.card.MaterialCardView>
                <!-- INFO -->

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="10dp"
                    android:orientation="vertical">

                    <!-- NAME -->

                    <TextView
                        android:id="@+id/tvFarmerName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ramesh Sharma"
                        android:textColor="?android:textColorPrimary"
                        android:textStyle="bold"
                        android:textSize="14sp"/>

                    <!-- CODE -->

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tvFarmerCode"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="# FM-00142"
                            android:textColor="?android:textColorSecondary"
                            android:textSize="10sp"/>

                        <!-- DOT -->

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="6dp"
                            android:text="•"
                            android:textColor="?android:textColorSecondary"
                            android:textSize="10sp"/>

                        <!-- SMALL STATUS TEXT -->

                        <TextView
                            android:id="@+id/tvSmallStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="6dp"
                            android:text="Active"
                            android:textColor="?android:textColorSecondary"
                            android:textSize="10sp"/>

                    </LinearLayout>

                </LinearLayout>

                <!-- MILK TYPE -->

                <TextView
                    android:id="@+id/tvMilkType"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="6dp"
                    android:background="@drawable/bg_chip_green"
                    android:paddingStart="10dp"
                    android:paddingTop="5dp"
                    android:paddingEnd="10dp"
                    android:paddingBottom="5dp"
                    android:text="COW"
                    android:textColor="#10B26C"
                    android:textStyle="bold"
                    android:textSize="9sp"/>

                <!-- STATUS -->

                <TextView
                    android:id="@+id/tvStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_chip_green"
                    android:paddingStart="10dp"
                    android:paddingTop="5dp"
                    android:paddingEnd="10dp"
                    android:paddingBottom="5dp"
                    android:text="ACTIVE"
                    android:textColor="#10B26C"
                    android:textStyle="bold"
                    android:textSize="9sp"/>

            </LinearLayout>
            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="3dp"
                android:layout_marginBottom="3dp"
                app:cardBackgroundColor="?attr/colorSurface"/>

            <!-- Bottom -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <!-- Mobile -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <!-- Phone Box -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/btnCallFarmer"
                        android:layout_width="34dp"
                        android:layout_height="34dp"
                        android:layout_marginStart="2dp"
                        app:cardBackgroundColor="?attr/colorSurface"
                        app:cardCornerRadius="10dp"
                        app:cardElevation="1dp">

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent">

                            <ImageView
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:layout_gravity="center"
                                android:src="@drawable/phone" />

                        </FrameLayout>

                    </com.google.android.material.card.MaterialCardView>

                    <!-- Mobile -->
                    <TextView
                        android:id="@+id/tvMobile"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="+91 98765 43210"
                        android:textColor="?android:textColorPrimary"
                        android:textSize="11sp" />
                </LinearLayout>

                <!-- ACTIONS -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Edit -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/btnEdit"
                        android:layout_width="42dp"
                        android:layout_height="42dp"
                        android:layout_marginEnd="8dp"
                        app:cardBackgroundColor="?attr/colorSurface"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="1dp">

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent">

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:layout_gravity="center"
                                android:src="@drawable/edit"
                                app:tint="#2563EB" />

                        </FrameLayout>

                    </com.google.android.material.card.MaterialCardView>

                    <!-- Delete -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/btnDelete"
                        android:layout_width="42dp"
                        android:layout_height="42dp"
                        app:cardBackgroundColor="?attr/colorSurface"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="1dp">

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent">

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:layout_gravity="center"
                                android:src="@drawable/bin" />

                        </FrameLayout>

                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

            </LinearLayout>
        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>