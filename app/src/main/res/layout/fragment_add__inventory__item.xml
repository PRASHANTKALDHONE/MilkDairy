<?xml version="1.0" encoding="utf-8"?>

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?android:colorBackground"
    android:padding="14dp">

    <!-- TOP BAR -->

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="22dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="@android:color/transparent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/side_nav_bar"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="16dp">

            <!-- BACK -->

            <LinearLayout
                android:id="@+id/btnBack"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@drawable/bg_glass_circle"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="←"
                    android:textColor="@android:color/white"
                    android:textSize="18sp"
                    android:textStyle="bold"/>

            </LinearLayout>

            <!-- TITLE -->

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Add Inventory"
                    android:textColor="@android:color/white"
                    android:textSize="18sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Create new stock item"
                    android:textColor="#DDE7FF"
                    android:textSize="10sp"/>

            </LinearLayout>

            <!-- CODE -->

            <TextView
                android:id="@+id/txtItemCode"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:background="@drawable/bg_glass_card"
                android:gravity="center"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:text="I001"
                android:textColor="@android:color/white"
                android:textSize="11sp"
                android:textStyle="bold"/>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- FORM CARD -->

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:layout_weight="1"
        app:cardCornerRadius="20dp"
        app:cardElevation="0dp"
        app:strokeWidth="1dp"
        app:strokeColor="#E5E7EB"
        app:cardBackgroundColor="?attr/colorSurface">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="14dp">

            <!-- ITEM NAME -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Item Name"
                android:textColor="?android:textColorPrimary"
                android:textSize="11sp"
                android:textStyle="bold"/>

            <EditText
                android:id="@+id/etItemName"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="5dp"
                android:background="@drawable/bg_edittext_inventory"
                android:hint="Enter item name"
                android:paddingHorizontal="12dp"
                android:textColor="?android:textColorPrimary"
                android:textColorHint="?android:textColorSecondary"
                android:textSize="12sp"/>

            <!-- CATEGORY -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Category"
                android:textColor="?android:textColorPrimary"
                android:textSize="11sp"
                android:textStyle="bold"/>

            <EditText
                android:id="@+id/etCategory"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="5dp"
                android:background="@drawable/bg_edittext_inventory"
                android:hint="Feed / Medicine"
                android:paddingHorizontal="12dp"
                android:textColor="?android:textColorPrimary"
                android:textColorHint="?android:textColorSecondary"
                android:textSize="12sp"/>

            <!-- UNIT -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Unit"
                android:textColor="?android:textColorPrimary"
                android:textSize="11sp"
                android:textStyle="bold"/>

            <EditText
                android:id="@+id/etUnit"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="5dp"
                android:background="@drawable/bg_edittext_inventory"
                android:hint="Kg / Ltr / Piece"
                android:paddingHorizontal="12dp"
                android:textColor="?android:textColorPrimary"
                android:textColorHint="?android:textColorSecondary"
                android:textSize="12sp"/>

            <!-- MINIMUM STOCK -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Minimum Stock"
                android:textColor="?android:textColorPrimary"
                android:textSize="11sp"
                android:textStyle="bold"/>

            <EditText
                android:id="@+id/etMinimumStock"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="5dp"
                android:background="@drawable/bg_edittext_inventory"
                android:hint="0"
                android:inputType="numberDecimal"
                android:paddingHorizontal="12dp"
                android:textColor="?android:textColorPrimary"
                android:textColorHint="?android:textColorSecondary"
                android:textSize="12sp"/>

            <!-- OPENING STOCK -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Opening Stock"
                android:textColor="?android:textColorPrimary"
                android:textSize="11sp"
                android:textStyle="bold"/>

            <EditText
                android:id="@+id/etOpeningStock"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="5dp"
                android:background="@drawable/bg_edittext_inventory"
                android:hint="0"
                android:inputType="numberDecimal"
                android:paddingHorizontal="12dp"
                android:textColor="?android:textColorPrimary"
                android:textColorHint="?android:textColorSecondary"
                android:textSize="12sp"/>

            <!-- PURCHASE RATE -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Purchase Rate"
                android:textColor="?android:textColorPrimary"
                android:textSize="11sp"
                android:textStyle="bold"/>

            <EditText
                android:id="@+id/etPurchaseRate"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="5dp"
                android:background="@drawable/bg_edittext_inventory"
                android:hint="₹ 0"
                android:inputType="numberDecimal"
                android:paddingHorizontal="12dp"
                android:textColor="?android:textColorPrimary"
                android:textColorHint="?android:textColorSecondary"
                android:textSize="12sp"/>

            <!-- SELLING RATE -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Selling Rate"
                android:textColor="?android:textColorPrimary"
                android:textSize="11sp"
                android:textStyle="bold"/>

            <EditText
                android:id="@+id/etSellingRate"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="5dp"
                android:background="@drawable/bg_edittext_inventory"
                android:hint="₹ 0"
                android:inputType="numberDecimal"
                android:paddingHorizontal="12dp"
                android:textColor="?android:textColorPrimary"
                android:textColorHint="?android:textColorSecondary"
                android:textSize="12sp"/>

            <!-- BUTTONS -->

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="end"
                android:orientation="horizontal"
                android:weightSum="3">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCancel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Cancel"
                    android:textAllCaps="false"
                    android:textSize="12sp"
                    android:backgroundTint="?attr/colorSurface"
                    android:textColor="?android:textColorPrimary"/>

                <Space
                    android:layout_width="6dp"
                    android:layout_height="match_parent"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnReset"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Reset"
                    android:textAllCaps="false"
                    android:textSize="12sp"
                    android:backgroundTint="?attr/colorSurface"
                    android:textColor="?android:textColorPrimary"/>

                <Space
                    android:layout_width="6dp"
                    android:layout_height="match_parent"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSave"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Save"
                    android:textAllCaps="false"
                    android:textSize="12sp"
                    android:backgroundTint="?attr/colorSurface"
                    android:textColor="?android:textColorPrimary"/>

            </LinearLayout>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

</LinearLayout>