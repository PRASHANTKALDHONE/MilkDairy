<?xml version="1.0" encoding="utf-8"?>

<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="10dp"
    android:layout_marginTop="5dp"
    android:layout_marginEnd="10dp"
    android:layout_marginBottom="5dp"
    app:cardBackgroundColor="?attr/colorSurface"
    app:cardCornerRadius="18dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#10B26C"/>

        <!-- TOP SECTION -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:padding="5dp"
            android:orientation="horizontal">

            <!-- AVATAR -->

            <LinearLayout
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:gravity="center">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    app:cardBackgroundColor="?attr/colorSurface"
                    app:cardCornerRadius="25dp"
                    android:layout_marginStart="4dp"
                    app:cardElevation="1dp">

                    <TextView
                        android:id="@+id/txtCode"
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:gravity="center"
                        android:text="SK"
                        android:textColor="#10B26C"
                        android:textSize="16sp"
                        android:textStyle="bold"/>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <!-- INFO -->

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:orientation="vertical">

                <!-- ITEM NAME -->

                <TextView
                    android:id="@+id/txtItemName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="Premium Cattle Feed"
                    android:textColor="?android:textColorPrimary"
                    android:textSize="13sp"
                    android:textStyle="bold"/>

                <!-- CATEGORY -->

                <TextView
                    android:id="@+id/txtCategory"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Feed Category"
                    android:textColor="?android:textColorSecondary"
                    android:textSize="9sp"/>

                <!-- UPDATED -->

                <TextView
                    android:id="@+id/txtLastUpdated"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Updated today"
                    android:textColor="#14B8A6"
                    android:textSize="8sp"
                    android:textStyle="bold"/>

            </LinearLayout>

            <!-- STOCK -->

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/txtStock"
                    android:layout_width="62dp"
                    android:layout_height="25dp"
                    android:background="@drawable/bg_button_paid"
                    android:gravity="center"
                    android:text="12 KG"
                    android:textColor="?android:textColorPrimary"
                    android:textSize="9sp"
                    android:textStyle="bold"/>

                <ImageButton
                    android:id="@+id/btnMenu"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginStart="6dp"
                    android:background="@android:color/transparent"
                    android:src="@drawable/more"
                    android:scaleType="fitCenter"/>

            </LinearLayout>
        </LinearLayout>

        <!-- DIVIDER -->

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="3dp"
            android:layout_marginBottom="3dp"
            app:cardBackgroundColor="?attr/colorSurface"/>

        <!-- DETAILS -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="1dp"
            android:layout_marginBottom="1dp"
            android:orientation="horizontal"
            android:weightSum="3">

            <!-- MIN STOCK -->

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MIN STOCK"
                    android:textColor="?android:textColorSecondary"
                    android:textSize="7sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/txtMinStock"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="20 KG"
                    android:textColor="?android:textColorPrimary"
                    android:textSize="12sp"
                    android:textStyle="bold"/>

            </LinearLayout>

            <!-- PURCHASE RATE -->

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="RATE"
                    android:textColor="?android:textColorSecondary"
                    android:textSize="7sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/txtPurchaseRate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="₹950"
                    android:textColor="?android:textColorPrimary"
                    android:textSize="12sp"
                    android:textStyle="bold"/>

            </LinearLayout>

            <!-- STOCK VALUE -->

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="VALUE"
                    android:textColor="?android:textColorSecondary"
                    android:textSize="7sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/txtStockValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="₹1,14,000"
                    android:textColor="?android:textColorPrimary"
                    android:textSize="12sp"
                    android:textStyle="bold"/>

            </LinearLayout>

        </LinearLayout>
        <!-- ACTIONS -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="2dp"
            android:layout_marginTop="5dp"
            android:orientation="horizontal"
            android:weightSum="3">

            <!-- STOCK IN -->

            <TextView
                android:id="@+id/btnStockIn"
                android:layout_width="0dp"
                android:layout_height="34dp"
                android:layout_weight="1"
                android:layout_marginEnd="3dp"
                android:layout_marginStart="2dp"
                android:background="@drawable/bg_button_paid"
                android:gravity="center"
                android:text="Stock In"
                android:textColor="?android:textColorPrimary"
                android:textSize="9sp"
                android:textStyle="bold"/>

            <!-- STOCK OUT -->

            <TextView
                android:id="@+id/btnStockOut"
                android:layout_width="0dp"
                android:layout_height="34dp"
                android:layout_weight="1"
                android:layout_marginHorizontal="4dp"
                android:background="@drawable/bg_button_paid"
                android:gravity="center"
                android:text="Stock Out"
                android:textColor="?android:textColorPrimary"
                android:textSize="9sp"
                android:textStyle="bold"/>

            <!-- SELL -->

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSell"
                android:layout_width="0dp"
                android:layout_height="34dp"
                android:layout_weight="1"
                android:layout_marginStart="3dp"
                android:layout_marginEnd="2dp"
                android:minWidth="0dp"
                android:background="@drawable/bg_button_paid"
                android:text="Sell"
                android:textAllCaps="false"
                android:textColor="?android:textColorPrimary"
                android:textSize="9sp"
                android:textStyle="bold"
                app:elevation="0dp"/>
        </LinearLayout>
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>