<?xml version="1.0" encoding="utf-8"?>

<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:colorBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Header -->
        <!-- Header -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:cardBackgroundColor="@android:color/transparent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/side_nav_bar"
                android:orientation="vertical"
                android:padding="14dp">

                <!-- TOP -->

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Food Deduction"
                            android:textColor="@android:color/white"
                            android:textSize="20sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Manage farmer food deductions"
                            android:textColor="#DDE7FF"
                            android:textSize="11sp"
                            android:layout_marginTop="2dp"/>

                    </LinearLayout>

                </LinearLayout>

                <!-- STATS -->

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="horizontal"
                    android:weightSum="4">

                    <!-- TOTAL -->

                    <include
                        android:id="@+id/statTotal"
                        layout="@layout/item_dashboard_stat"/>

                    <!-- AMOUNT -->

                    <include
                        android:id="@+id/statAmount"
                        layout="@layout/item_dashboard_stat"/>

                    <!-- PENDING -->

                    <include
                        android:id="@+id/statPending"
                        layout="@layout/item_dashboard_stat"/>

                    <!-- CLEARED -->

                    <include
                        android:id="@+id/statCleared"
                        layout="@layout/item_dashboard_stat"/>

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- ================================================= -->
        <!-- SMART FILTER HEADER -->
        <!-- ================================================= -->

        <!-- ================================================= -->
        <!-- SMART FILTER HEADER -->
        <!-- ================================================= -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <!-- LEFT -->

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:gravity="center"
                    android:background="@drawable/bg_action_box">

                    <ImageView
                        android:layout_width="13dp"
                        android:layout_height="13dp"
                        android:src="@drawable/sort"
                        app:tint="#667085"/>

                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="SMART FILTERS"
                    android:textColor="?android:textColorPrimary"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.04"/>

            </LinearLayout>

            <!-- CLEAR -->

            <TextView
                android:id="@+id/tvClearAll"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingStart="10dp"
                android:paddingTop="4dp"
                android:paddingEnd="10dp"
                android:paddingBottom="4dp"
                android:text="Clear"
                android:textColor="#2563EB"
                android:textSize="9sp"
                android:textStyle="bold"/>

        </LinearLayout>

        <!-- ================================================= -->
        <!-- ADVANCED FILTER SECTION -->
        <!-- ================================================= -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:orientation="vertical">

            <!-- ================================================= -->
            <!-- DATE FILTER -->
            <!-- ================================================= -->

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="18dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="?attr/colorSurface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="10dp">

                    <!-- TOP -->

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <!-- ICON -->

                        <LinearLayout
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:gravity="center"
                            android:background="@drawable/bg_action_box">

                            <ImageView
                                android:layout_width="12dp"
                                android:layout_height="12dp"
                                android:src="@drawable/calendar"
                                app:tint="#0097A7"/>

                        </LinearLayout>

                        <!-- TITLE -->

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Date Filter"
                                android:textColor="?android:textColorPrimary"
                                android:textStyle="bold"
                                android:textSize="12sp"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Filter records"
                                android:textColor="?android:textColorSecondary"
                                android:textSize="8sp"/>

                        </LinearLayout>

                    </LinearLayout>

                    <!-- BUTTONS -->

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:orientation="horizontal">

                        <!-- THIS MONTH -->

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnThisMonth"
                            android:layout_width="0dp"
                            android:layout_height="36dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="4dp"
                            android:text="Month"
                            android:textAllCaps="false"
                            android:textColor="@android:color/white"
                            android:textSize="9sp"
                            android:textStyle="bold"
                            app:backgroundTint="#0097A7"
                            app:cornerRadius="10dp"
                            app:elevation="0dp"/>

                        <!-- ALL -->

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnAll"
                            android:layout_width="0dp"
                            android:layout_height="36dp"
                            android:layout_weight="1"
                            android:layout_marginHorizontal="2dp"
                            android:text="All"
                            android:textAllCaps="false"
                            android:textColor="#667085"
                            android:textSize="9sp"
                            android:textStyle="bold"
                            app:backgroundTint="#F4F7FA"
                            app:cornerRadius="10dp"
                            app:elevation="0dp"
                            app:strokeWidth="1dp"
                            app:strokeColor="#E5E7EB"/>

                        <!-- RANGE -->

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnRange"
                            android:layout_width="0dp"
                            android:layout_height="36dp"
                            android:layout_weight="1"
                            android:layout_marginStart="4dp"
                            android:text="Range"
                            android:textAllCaps="false"
                            android:textColor="#667085"
                            android:textSize="9sp"
                            android:textStyle="bold"
                            app:backgroundTint="#F4F7FA"
                            app:cornerRadius="10dp"
                            app:elevation="0dp"
                            app:strokeWidth="1dp"
                            app:strokeColor="#E5E7EB"/>

                    </LinearLayout>

                    <!-- RANGE DATE -->

                    <LinearLayout
                        android:id="@+id/layoutDateRange"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="horizontal"
                        android:visibility="gone">

                        <!-- FROM -->

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="40dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="4dp"
                            android:background="@drawable/bg_edittext"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingHorizontal="10dp">

                            <ImageView
                                android:layout_width="12dp"
                                android:layout_height="12dp"
                                android:src="@drawable/calendar"
                                app:tint="#98A2B3"/>

                            <EditText
                                android:id="@+id/etFromDate"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginStart="6dp"
                                android:background="@android:color/transparent"
                                android:focusable="false"
                                android:hint="From"
                                android:textColor="?android:textColorPrimary"
                                android:textColorHint="#98A2B3"
                                android:textSize="10sp"/>

                        </LinearLayout>

                        <!-- TO -->

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="40dp"
                            android:layout_weight="1"
                            android:layout_marginStart="4dp"
                            android:background="@drawable/bg_edittext"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingHorizontal="10dp">

                            <ImageView
                                android:layout_width="12dp"
                                android:layout_height="12dp"
                                android:src="@drawable/calendar"
                                app:tint="#98A2B3"/>

                            <EditText
                                android:id="@+id/etToDate"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginStart="6dp"
                                android:background="@android:color/transparent"
                                android:focusable="false"
                                android:hint="To"
                                android:textColor="?android:textColorPrimary"
                                android:textColorHint="#98A2B3"
                                android:textSize="10sp"/>

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- ================================================= -->
            <!-- CATEGORY + STATUS -->
            <!-- ================================================= -->

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <!-- CATEGORY -->

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/layoutCategoryFilter"
                    android:layout_width="0dp"
                    android:layout_height="64dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="3dp"
                    app:cardBackgroundColor="?attr/colorSurface">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:paddingStart="12dp"
                        android:paddingTop="8dp"
                        android:paddingEnd="10dp"
                        android:paddingBottom="8dp">

                        <!-- TITLE -->

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="CATEGORY"
                            android:textColor="?android:textColorSecondary"
                            android:textSize="7sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.08"/>

                        <!-- VALUE -->

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="5dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/tvCategoryFilter"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="🍛 Food"
                                android:textColor="?android:textColorPrimary"
                                android:textStyle="bold"
                                android:textSize="12sp"/>

                            <ImageView
                                android:layout_width="9dp"
                                android:layout_height="9dp"
                                android:src="@drawable/down"
                                app:tint="#98A2B3"/>

                        </LinearLayout>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- STATUS -->

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/layoutStatusFilter"
                    android:layout_width="0dp"
                    android:layout_height="64dp"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="3dp"
                    app:cardBackgroundColor="?attr/colorSurface">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:paddingStart="12dp"
                        android:paddingTop="8dp"
                        android:paddingEnd="10dp"
                        android:paddingBottom="8dp">

                        <!-- TITLE -->

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="STATUS"
                            android:textColor="?android:textColorSecondary"
                            android:textSize="7sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.08"/>

                        <!-- VALUE -->

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="5dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <View
                                android:layout_width="8dp"
                                android:layout_height="8dp"
                                android:background="@drawable/bg_online_dot"/>

                            <TextView
                                android:id="@+id/tvStatusFilter"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginStart="6dp"
                                android:text="Cleared"
                                android:textColor="?android:textColorPrimary"
                                android:textStyle="bold"
                                android:textSize="12sp"/>

                            <ImageView
                                android:layout_width="9dp"
                                android:layout_height="9dp"
                                android:src="@drawable/down"
                                app:tint="#98A2B3"/>

                        </LinearLayout>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

        </LinearLayout>

        <!-- ================================================= -->
        <!-- SEARCH -->
        <!-- ================================================= -->

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:layout_marginBottom="4dp"
            app:cardBackgroundColor="?attr/colorSurface"
            app:cardCornerRadius="14dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="12dp">

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/search"/>

                <EditText
                    android:id="@+id/etSearch"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:background="@android:color/transparent"
                    android:hint="Search farmer or deduction..."
                    android:textColor="?android:textColorSecondary"
                    android:textColorHint="#98A2B3"
                    android:textSize="11sp"/>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>
        <!-- ================================================= -->
        <!-- RECYCLER -->
        <!-- ================================================= -->

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <!-- RECYCLER -->

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvFoodDeduction"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:paddingBottom="100dp"
                android:scrollbars="vertical"/>

            <!-- PROGRESS -->

            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:layout_gravity="center"
                android:visibility="gone"/>

            <!-- EMPTY -->

            <LinearLayout
                android:id="@+id/layoutEmpty"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="24dp"
                android:visibility="gone">

                <ImageView
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:src="@drawable/advancedsearch"
                    app:tint="?android:textColorSecondary"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="No deductions found"
                    android:textColor="?android:textColorPrimary"
                    android:textSize="18sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Add deduction to get started"
                    android:textColor="?android:textColorSecondary"
                    android:textSize="14sp"/>

            </LinearLayout>

        </FrameLayout>

    </LinearLayout>

    <!-- ================================================= -->
    <!-- FAB -->
    <!-- ================================================= -->

    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/fabAddFood"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:layout_gravity="bottom|right"
        android:textColor="@android:color/white"
        app:backgroundTint="#009688"
        app:icon="@drawable/plus"
        app:iconTint="@android:color/white"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>