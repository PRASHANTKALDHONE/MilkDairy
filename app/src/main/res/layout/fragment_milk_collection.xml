<?xml version="1.0" encoding="utf-8"?>

<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:colorBackground"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="10dp"
        android:paddingTop="10dp"
        android:paddingEnd="10dp"
        android:paddingBottom="10dp">

        <!-- ================================================= -->
        <!-- HEADER -->
        <!-- ================================================= -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Milk Collection"
                    android:textColor="?android:textColorPrimary"
                    android:textSize="18sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Manage daily milk collection records"
                    android:textColor="?android:textColorSecondary"
                    android:textSize="11sp"/>

            </LinearLayout>

        </LinearLayout>

        <!-- ================================================= -->
        <!-- CAN PLATFORM -->
        <!-- ================================================= -->

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            app:cardBackgroundColor="?attr/colorSurface"
            app:cardCornerRadius="22dp"
            app:cardElevation="3dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <!-- HEADER -->

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <!-- LEFT SIDE -->

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <!-- TITLE ROW -->

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/milk"
                                app:tint="#F97316" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="6dp"
                                android:text="MILK CAN PLATFORM"
                                android:textColor="?android:textColorPrimary"
                                android:textSize="13sp"
                                android:textStyle="bold" />

                        </LinearLayout>

                        <!-- CAPACITY ROW -->

                        <TextView
                            android:id="@+id/tvCanCapacity"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Cow 40L • Buffalo 40L • Mix 40L"
                            android:textColor="?android:textColorSecondary"
                            android:textSize="9sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <!-- SETTINGS BUTTON -->

                    <ImageView
                        android:id="@+id/btnCanSettings"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_marginStart="8dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:clickable="true"
                        android:focusable="true"
                        android:padding="2dp"
                        android:src="@drawable/control"
                        app:tint="?android:textColorSecondary" />

                    <!-- SHIFT SWITCH -->

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:layout_marginStart="10dp"
                        android:background="@drawable/bg_shift_switch"
                        android:orientation="horizontal"
                        android:padding="3dp">

                        <TextView
                            android:id="@+id/tvMorning"
                            android:layout_width="54dp"
                            android:layout_height="match_parent"
                            android:background="@drawable/bg_summary_card"
                            android:gravity="center"
                            android:text="☀ Mor"
                            android:textColor="@android:color/white"
                            android:textSize="10sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvEvening"
                            android:layout_width="54dp"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:text="🌙 Eve"
                            android:textColor="?android:textColorPrimary"
                            android:textSize="10sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                </LinearLayout>
                <!-- PLATFORM -->

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:orientation="horizontal"
                    android:weightSum="3">

                    <include
                        layout="@layout/platform_cow"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"/>

                    <include
                        layout="@layout/platform_buffalo"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"/>

                    <include
                        layout="@layout/platform_mix"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"/>

                </LinearLayout>

                <!-- ================================================= -->
                <!-- ADD ENTRY BUTTON -->
                <!-- ================================================= -->

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnAddMilkEntry"
                    android:layout_width="match_parent"
                    android:layout_height="35dp"
                    android:layout_marginTop="14dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    app:cardBackgroundColor="@android:color/transparent"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_summary_card"
                        android:gravity="center"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:layout_marginEnd="10dp"
                            android:background="@drawable/bg_add_entry_icon"
                            android:gravity="center">

                            <ImageView
                                android:layout_width="15dp"
                                android:layout_height="15dp"
                                android:src="@drawable/milk"
                                app:tint="@android:color/white"/>

                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="+ Add Milk Entry"
                            android:textColor="@android:color/white"
                            android:textSize="15sp"
                            android:textStyle="bold"/>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- ================================================= -->
        <!-- COLLECTION HISTORY -->
        <!-- ================================================= -->

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardCollections"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:minHeight="320dp"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="10dp"
            app:cardBackgroundColor="?attr/colorSurface"
            app:cardCornerRadius="22dp"
            app:cardElevation="3dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="14dp">

                <!-- TOP SECTION -->

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <!-- TITLE -->

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Collection History"
                            android:textColor="?android:textColorPrimary"
                            android:textSize="15sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Today's milk collection entries"
                            android:textColor="?android:textColorSecondary"
                            android:textSize="10sp"/>

                    </LinearLayout>

                    <!-- COUNT -->

                    <!-- COUNT -->

                    <LinearLayout
                        android:id="@+id/layoutRecordCount"
                        android:layout_width="wrap_content"
                        android:layout_height="30dp"
                        android:background="@drawable/bg_search_farmer"
                        android:gravity="center"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp">

                        <TextView
                            android:id="@+id/tvRecordCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="132 Records"
                            android:textColor="#14B8A6"
                            android:textSize="10sp"
                            android:textStyle="bold"/>

                    </LinearLayout>
                </LinearLayout>

                <!-- FILTER BAR -->

                <!-- ===================================================== -->
                <!-- FILTER + DATE SELECTION BAR -->
                <!-- PROFESSIONAL DROPDOWN STRUCTURE -->
                <!-- ===================================================== -->

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:layout_marginBottom="4dp"
                    app:cardBackgroundColor="?attr/colorSurface"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="3dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="46dp"
                        android:background="@drawable/bg_search_farmer"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="6dp"
                        android:paddingEnd="6dp"
                        android:weightSum="2">

                        <!-- FILTER DROPDOWN -->
                        <LinearLayout
                            android:id="@+id/layoutFilter"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?attr/selectableItemBackgroundBorderless"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp">

                            <ImageView
                                android:layout_width="14dp"
                                android:layout_height="14dp"
                                android:src="@drawable/sort"
                                app:tint="#667085"/>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginStart="7dp"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="FILTER"
                                    android:textColor="#98A2B3"
                                    android:textSize="8sp"
                                    android:textStyle="bold"/>

                                <TextView
                                    android:id="@+id/tvSelectedFilter"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Daily"
                                    android:textColor="?android:textColorSecondary"
                                    android:textSize="11sp"
                                    android:textStyle="bold"/>

                            </LinearLayout>

                            <ImageView
                                android:layout_width="10dp"
                                android:layout_height="10dp"
                                android:src="@drawable/down"
                                app:tint="#98A2B3"/>

                        </LinearLayout>

                        <!-- DIVIDER -->
                        <View
                            android:layout_width="1dp"
                            android:layout_height="22dp"
                            android:background="#E5E7EB"/>

                        <!-- DATE PICKER -->
                        <LinearLayout
                            android:id="@+id/layoutDatePicker"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?attr/selectableItemBackgroundBorderless"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp">

                            <ImageView
                                android:layout_width="14dp"
                                android:layout_height="14dp"
                                android:src="@drawable/ic_calendar"
                                app:tint="#98A2B3"/>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginStart="7dp"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="DATE"
                                    android:textColor="#98A2B3"
                                    android:textSize="8sp"
                                    android:textStyle="bold"/>

                                <TextView
                                    android:id="@+id/etFilterDate"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="19 May 2026"
                                    android:textColor="?android:textColorSecondary"
                                    android:textSize="11sp"
                                    android:textStyle="bold"/>

                            </LinearLayout>

                            <ImageView
                                android:layout_width="10dp"
                                android:layout_height="10dp"
                                android:src="@drawable/down"
                                app:tint="#98A2B3"/>

                        </LinearLayout>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>                <!-- RECYCLER -->

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:layout_marginTop="14dp">

                    <!-- Milk Collection List -->

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recyclerMilkCollection"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:clipToPadding="false"
                        android:nestedScrollingEnabled="true"
                        android:overScrollMode="never"
                        android:paddingBottom="100dp"
                        android:scrollbars="vertical" />

                    <!-- Loading -->

                    <ProgressBar
                        android:id="@+id/progressMilkCollection"
                        android:layout_width="42dp"
                        android:layout_height="42dp"
                        android:layout_gravity="center"
                        android:visibility="gone" />

                    <!-- Empty State -->

                    <LinearLayout
                        android:id="@+id/layoutEmptyMilkCollection"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="24dp"
                        android:visibility="gone">

                        <ImageView
                            android:layout_width="72dp"
                            android:layout_height="72dp"
                            android:src="@drawable/milkcan"
                            app:tint="?android:textColorSecondary" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="No milk collection found"
                            android:textColor="?android:textColorPrimary"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvEmptyMilkCollectionSub"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Add milk collection to get started"
                            android:textColor="?android:textColorSecondary"
                            android:textSize="14sp" />

                    </LinearLayout>

                </FrameLayout>
            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</LinearLayout>