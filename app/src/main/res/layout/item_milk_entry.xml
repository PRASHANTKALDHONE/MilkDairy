<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="8dp">

    <TextView android:id="@+id/tvShift" android:layout_width="90dp" android:layout_height="wrap_content"/>
    <TextView android:id="@+id/tvFarmer" android:layout_width="150dp" android:layout_height="wrap_content"/>
    <TextView android:id="@+id/tvMobile" android:layout_width="120dp" android:layout_height="wrap_content"/>
    <TextView android:id="@+id/tvLiters" android:layout_width="80dp" android:layout_height="wrap_content"/>
    <TextView android:id="@+id/tvFat" android:layout_width="80dp" android:layout_height="wrap_content"/>
    <TextView android:id="@+id/tvSnf" android:layout_width="80dp" android:layout_height="wrap_content"/>
    <TextView android:id="@+id/tvRate" android:layout_width="80dp" android:layout_height="wrap_content"/>
    <TextView android:id="@+id/tvAmount" android:layout_width="100dp" android:layout_height="wrap_content"/>

</LinearLayout>