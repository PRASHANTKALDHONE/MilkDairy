<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:colorBackground"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ===== HEADER SECTION ===== -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:background="@drawable/side_nav_bar"
            android:padding="20dp">

            <!-- Left: Greeting Text -->
            <LinearLayout
                android:id="@+id/layoutGreeting"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvGreeting"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Good Morning"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/schedule"
                        android:contentDescription="Calendar" />

                    <TextView
                        android:id="@+id/tvDashboardDate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:text="29 May 2026, Thursday"
                        android:textColor="#CCFFFFFF"
                        android:textSize="13sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Right: Milk Jug & Splash Image -->
            <ImageView
                android:layout_width="160dp"
                android:layout_height="140dp"
                android:layout_alignParentEnd="true"
                android:layout_alignParentBottom="true"
                android:src="@drawable/ic_milk_splash"
                android:contentDescription="Milk Splash"
                android:scaleType="fitEnd" />

            <!-- Background house silhouette (decorative) -->
            <ImageView
                android:layout_width="120dp"
                android:layout_height="90dp"
                android:layout_alignParentEnd="true"
                android:layout_alignParentTop="true"
                android:layout_marginEnd="130dp"
                android:layout_marginTop="10dp"
                android:src="@drawable/ic_house_silhouette"
                android:contentDescription=""
                android:alpha="0.25"
                android:scaleType="fitCenter" />
        </RelativeLayout>

        <!-- ===== STATS CARD ===== -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:layout_marginTop="-22dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="3dp"
            app:cardBackgroundColor="?attr/colorSurface"
            app:strokeColor="#22000000"
            app:strokeWidth="0.5dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="14dp"
                android:weightSum="4">

                <!-- MILK -->

                <LinearLayout
                    android:id="@+id/cardMilkStats"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/milkcan"
                        app:tint="?attr/colorPrimary"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="5dp"
                        android:text="Milk"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="10sp"/>

                    <TextView
                        android:id="@+id/tvMilkLiters"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="1259 L"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="14sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/tvMilkAmount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="₹74K"
                        android:textColor="?attr/colorPrimary"
                        android:textSize="10sp"
                        android:textStyle="bold"/>

                </LinearLayout>

                <View
                    android:layout_width="1dp"
                    android:layout_height="70dp"
                    android:background="#22000000"/>

                <!-- INVENTORY -->

                <LinearLayout
                    android:id="@+id/cardInventoryStats"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/productmanagement"
                        app:tint="?attr/colorPrimary"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="5dp"
                        android:text="Stock"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="10sp"/>

                    <TextView
                        android:id="@+id/tvInventoryValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="₹182K"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="14sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/tvInventoryLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Value"
                        android:textColor="?attr/colorPrimary"
                        android:textSize="10sp"
                        android:textStyle="bold"/>

                </LinearLayout>

                <View
                    android:layout_width="1dp"
                    android:layout_height="70dp"
                    android:background="#22000000"/>

                <!-- BILLS -->

                <LinearLayout
                    android:id="@+id/cardBillsStats"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/bill"
                        app:tint="?attr/colorPrimary"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="5dp"
                        android:text="Bills"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="10sp"/>

                    <TextView
                        android:id="@+id/tvBillsCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="32"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="14sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/tvBillsAmount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="₹148K"
                        android:textColor="?attr/colorPrimary"
                        android:textSize="10sp"
                        android:textStyle="bold"/>

                </LinearLayout>

                <View
                    android:layout_width="1dp"
                    android:layout_height="70dp"
                    android:background="#22000000"/>

                <!-- FARMERS -->

                <LinearLayout
                    android:id="@+id/cardFarmersStats"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/farmer"
                        app:tint="?attr/colorPrimary"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="5dp"
                        android:text="Farmers"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="10sp"/>

                    <TextView
                        android:id="@+id/tvFarmersCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="156"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="14sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/tvFarmersLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Active"
                        android:textColor="?attr/colorPrimary"
                        android:textSize="10sp"
                        android:textStyle="bold"/>

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>
        <!-- ===== QUICK ACTIONS SECTION ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="12dp"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:orientation="vertical">

            <!-- HEADER -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Quick Actions"
                android:textColor="?attr/colorOnSurface"
                android:textSize="16sp"
                android:textStyle="bold"/>

            <!-- ROW 1 -->

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal"
                android:weightSum="3">

                <!-- FARMERS -->

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardManageFarmers"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    app:cardBackgroundColor="?attr/colorSurface"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="#22000000">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="92dp"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="8dp">

                        <ImageView
                            android:layout_width="42dp"
                            android:layout_height="42dp"
                            android:src="@drawable/ic_circle_manage_farmers"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="Add Farmers"
                            android:textColor="?attr/colorOnSurface"
                            android:textSize="11sp"
                            android:textStyle="bold"/>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- COLLECTION -->

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardMilkCollection"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="2dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    app:cardBackgroundColor="?attr/colorSurface"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="#22000000">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="92dp"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="8dp">

                        <ImageView
                            android:layout_width="42dp"
                            android:layout_height="42dp"
                            android:src="@drawable/ic_circle_milk_collection"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="Add Milk"
                            android:textColor="?attr/colorOnSurface"
                            android:textSize="11sp"
                            android:textStyle="bold"/>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- INVENTORY -->

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardInventory"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    app:cardBackgroundColor="?attr/colorSurface"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="#22000000">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="92dp"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="8dp">

                        <ImageView
                            android:layout_width="42dp"
                            android:layout_height="42dp"
                            android:src="@drawable/ic_circle_inventory_action"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="Inventory"
                            android:textColor="?attr/colorOnSurface"
                            android:textSize="11sp"
                            android:textStyle="bold"/>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <!-- ROW 2 -->

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal"
                android:weightSum="3">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardGenerateBill"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    app:cardBackgroundColor="?attr/colorSurface"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="#22000000">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="92dp"
                        android:gravity="center"
                        android:orientation="vertical">

                        <ImageView
                            android:layout_width="42dp"
                            android:layout_height="42dp"
                            android:src="@drawable/ic_circle_generate_bill"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="Bills"
                            android:textColor="?attr/colorOnSurface"
                            android:textSize="11sp"
                            android:textStyle="bold"/>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardAddDeduction"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="2dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    app:cardBackgroundColor="?attr/colorSurface"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="#22000000">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="92dp"
                        android:gravity="center"
                        android:orientation="vertical">

                        <ImageView
                            android:layout_width="42dp"
                            android:layout_height="42dp"
                            android:src="@drawable/ic_circle_add_deduction"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="Deduction"
                            android:textColor="?attr/colorOnSurface"
                            android:textSize="11sp"
                            android:textStyle="bold"/>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardViewReports"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    app:cardBackgroundColor="?attr/colorSurface"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="#22000000">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="92dp"
                        android:gravity="center"
                        android:orientation="vertical">

                        <ImageView
                            android:layout_width="42dp"
                            android:layout_height="42dp"
                            android:src="@drawable/ic_circle_view_reports"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="Reports"
                            android:textColor="?attr/colorOnSurface"
                            android:textSize="11sp"
                            android:textStyle="bold"/>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

        </LinearLayout>
        <!-- ===== MORNING & EVENING SHIFT SECTION ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:layout_marginBottom="10dp"
            android:orientation="horizontal"
            android:weightSum="2">

            <!-- MORNING -->

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                app:cardCornerRadius="18dp"
                app:cardElevation="1dp"
                app:cardBackgroundColor="?attr/colorSurface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🌅 Morning Shift"
                        android:textStyle="bold"
                        android:textSize="13sp"
                        android:textColor="?attr/colorOnSurface"/>

                    <!-- Cow -->

                    <LinearLayout
                        android:id="@+id/cardMorningCow"
                        android:layout_width="match_parent"
                        android:layout_height="38dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_stat_light"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="10dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="🐄 Cow"
                            android:textSize="11sp"/>

                        <TextView
                            android:id="@+id/tvMorningCow"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 L"
                            android:textStyle="bold"
                            android:textSize="11sp"/>

                    </LinearLayout>

                    <!-- Buffalo -->

                    <LinearLayout
                        android:id="@+id/cardMorningBuffalo"
                        android:layout_width="match_parent"
                        android:layout_height="38dp"
                        android:layout_marginTop="6dp"
                        android:background="@drawable/bg_stat_light"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="10dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="🐃 Buffalo"
                            android:textSize="11sp"/>

                        <TextView
                            android:id="@+id/tvMorningBuffalo"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 L"
                            android:textStyle="bold"
                            android:textSize="11sp"/>

                    </LinearLayout>

                    <!-- Mixed -->

                    <LinearLayout
                        android:id="@+id/cardMorningMixed"
                        android:layout_width="match_parent"
                        android:layout_height="38dp"
                        android:layout_marginTop="6dp"
                        android:background="@drawable/bg_stat_light"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="10dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="🥛 Mixed"
                            android:textSize="11sp"/>

                        <TextView
                            android:id="@+id/tvMorningMixed"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 L"
                            android:textStyle="bold"
                            android:textSize="11sp"/>

                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvMorningTotal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="Total: 0 L"
                        android:textColor="?attr/colorPrimary"
                        android:textStyle="bold"
                        android:textSize="12sp"/>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- EVENING -->

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                app:cardCornerRadius="18dp"
                app:cardElevation="1dp"
                app:cardBackgroundColor="?attr/colorSurface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🌙 Evening Shift"
                        android:textStyle="bold"
                        android:textSize="13sp"
                        android:textColor="?attr/colorOnSurface"/>

                    <LinearLayout
                        android:id="@+id/cardEveningCow"
                        android:layout_width="match_parent"
                        android:layout_height="38dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_stat_light"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="10dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="🐄 Cow"
                            android:textSize="11sp"/>

                        <TextView
                            android:id="@+id/tvEveningCow"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 L"
                            android:textStyle="bold"
                            android:textSize="11sp"/>

                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/cardEveningBuffalo"
                        android:layout_width="match_parent"
                        android:layout_height="38dp"
                        android:layout_marginTop="6dp"
                        android:background="@drawable/bg_stat_light"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="10dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="🐃 Buffalo"
                            android:textSize="11sp"/>

                        <TextView
                            android:id="@+id/tvEveningBuffalo"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 L"
                            android:textStyle="bold"
                            android:textSize="11sp"/>

                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/cardEveningMixed"
                        android:layout_width="match_parent"
                        android:layout_height="38dp"
                        android:layout_marginTop="6dp"
                        android:background="@drawable/bg_stat_light"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="10dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="🥛 Mixed"
                            android:textSize="11sp"/>

                        <TextView
                            android:id="@+id/tvEveningMixed"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 L"
                            android:textStyle="bold"
                            android:textSize="11sp"/>

                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvEveningTotal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="Total: 0 L"
                        android:textColor="?attr/colorPrimary"
                        android:textStyle="bold"
                        android:textSize="12sp"/>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>


        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:layout_marginStart="14dp"
            android:layout_marginEnd="12dp"
